---
const { paragraphs = [] } = Astro.props;
---

{paragraphs.length > 0 && (
  <section class="bridge" aria-label="Смысловой переход">
    <div class="bridge__inner">
      <div class="bridge__rail" aria-hidden="true"></div>

      <div class="bridge__content">
        {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>
)}

<style>
  .bridge {
    position: relative;
    padding: clamp(44px, 5vw, 68px) 0;
    background: #fff;
    color: var(--text, #1f1d1b);
    overflow: hidden;
  }

  .bridge__inner {
    position: relative;
    width: min(1440px, calc(100% - 64px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(32px, 5vw, 86px);
    align-items: center;
  }

  .bridge__rail {
    position: relative;
    height: 44px;
  }

  .bridge__rail::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(182, 70, 70, 0),
      rgba(182, 70, 70, 0.78)
    );
  }

  .bridge__rail::after {
    content: '';
    position: absolute;
    right: 0;
    top: calc(50% - 4px);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent, #b64646);
    box-shadow:
      -34px 0 0 rgba(182, 70, 70, 0.28),
      -68px 0 0 rgba(182, 70, 70, 0.12);
  }

  .bridge__content {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(24px, 3vw, 52px);
    padding: 28px 0;
    border-top: 1px solid rgba(182, 70, 70, 0.22);
    border-bottom: 1px solid rgba(31, 29, 27, 0.08);
  }

  .bridge__content p {
    margin: 0;
    max-width: 390px;
    color: rgba(31, 29, 27, 0.72);
    font-family: var(--font-text, system-ui, sans-serif);
    font-size: clamp(14px, 1.05vw, 17px);
    font-weight: 300;
    line-height: 1.62;
    letter-spacing: -0.01em;
  }

  .bridge__content p::first-letter {
    color: var(--accent, #b64646);
  }

  @media (max-width: 900px) {
    .bridge {
      padding: 38px 0;
    }

    .bridge__inner {
      width: calc(100% - 32px);
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .bridge__rail {
      width: 180px;
      height: 18px;
    }

    .bridge__content {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 24px 0;
    }

    .bridge__content p {
      max-width: 680px;
      font-size: 15px;
      line-height: 1.62;
    }
  }

  @media (max-width: 620px) {
    .bridge {
      padding: 34px 0;
    }

    .bridge__inner {
      width: calc(100% - 28px);
    }

    .bridge__content p {
      font-size: 14px;
      line-height: 1.58;
    }
  }
</style>