---
const facts = [
  {
    value: '4000+',
    label: 'клиентов по всему миру',
  },
  {
    value: '10 лет',
    label: 'практического опыта в астрологии',
  },
  {
    value: 'Основатель',
    label: 'школы классической астрологии',
  },
  {
    value: 'Эксперт',
    label: 'федеральных каналов ОРТ, ТВЦ, Эхо Москвы',
  },
  {
    value: 'Бакалавр',
    label: 'астрологии по школе К. Н. Дарагана',
  },
];
---

<section class="olga" id="about">
  <div class="olga__inner">
    <div class="olga__media">
      <img
        src="/images/olga-expert.webp"
        alt="Ольга Ткаченко"
        loading="lazy"
      />
    </div>

    <div class="olga__content">
      <p class="olga__eyebrow">Ольга Ткаченко</p>

      <h2>
        Эксперт, рядом с которым становится понятнее.
      </h2>

      <p class="olga__lead">
        Астрология здесь — не про мистику, а про структуру: увидеть себя,
        свои сценарии, сильные стороны и решения, которые подходят именно вам.
      </p>

      <div class="olga__facts">
        {facts.map((fact) => (
          <div class="olga__fact">
            <span>{fact.value}</span>
            <p>{fact.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .olga {
    position: relative;
    padding: clamp(86px, 10vw, 150px) 0;
    background: #fff;
    color: var(--text, #1f1d1b);
    overflow: hidden;
  }

  .olga::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    width: min(1440px, calc(100% - 64px));
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(
      90deg,
      transparent,
      rgba(182, 70, 70, 0.22),
      transparent
    );
  }

  .olga__inner {
    width: min(1440px, calc(100% - 64px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1.05fr);
    gap: clamp(48px, 7vw, 112px);
    align-items: center;
  }

  .olga__media {
    position: relative;
    min-height: clamp(500px, 52vw, 700px);
    overflow: hidden;
    border-radius: 34px;
    background: #f7f1eb;
    box-shadow: 0 34px 100px rgba(31, 29, 27, 0.08);
  }

  .olga__media img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .olga__eyebrow {
    margin: 0 0 18px;
    color: var(--accent, #b64646);
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .olga h2 {
    margin: 0;
    max-width: 600px;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(38px, 3.8vw, 56px);
    font-weight: 400;
    line-height: 1.04;
    letter-spacing: -0.03em;
  }

  .olga__lead {
    margin: 26px 0 0;
    max-width: 580px;
    color: rgba(31, 29, 27, 0.66);
    font-size: 17px;
    font-weight: 300;
    line-height: 1.7;
  }

  .olga__facts {
    margin-top: clamp(34px, 4vw, 52px);
    display: grid;
    border-top: 1px solid rgba(31, 29, 27, 0.1);
  }

  .olga__fact {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 26px;
    padding: 18px 0;
    border-bottom: 1px solid rgba(31, 29, 27, 0.1);
    align-items: baseline;
  }

  .olga__fact span {
    color: var(--accent, #b64646);
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(24px, 2.1vw, 34px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .olga__fact p {
    margin: 0;
    max-width: 430px;
    color: rgba(31, 29, 27, 0.72);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.55;
  }

  @media (max-width: 980px) {
    .olga__inner {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .olga__media {
      min-height: 620px;
    }

    .olga__content {
      max-width: 760px;
    }
  }

  @media (max-width: 620px) {
    .olga {
      padding: 68px 0;
    }

    .olga__inner {
      width: calc(100% - 32px);
      gap: 34px;
    }

    .olga::before {
      width: calc(100% - 32px);
    }

    .olga__media {
      min-height: 420px;
      border-radius: 26px;
    }

    .olga h2 {
      font-size: clamp(34px, 10vw, 46px);
      line-height: 1.04;
    }

    .olga__lead {
      font-size: 15px;
      line-height: 1.65;
    }

    .olga__fact {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 17px 0;
    }

    .olga__fact span {
      font-size: 28px;
    }

    .olga__fact p {
      font-size: 14px;
    }
  }
</style>
