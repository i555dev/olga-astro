---
const reviews = [
  {
    quote:
      'После первого разговора с бизнес-партнёром и изменения ролей в компании наша прибыль выросла в два раза. За восемь лет до этого выручка практически не менялась.',
    author: 'Марина Рой',
    result: 'Бизнес и партнёрство',
    image: '/images/reviews/marina-roy.webp',
  },
  {
    quote:
      'Благодаря консультации я ушла из найма и встроила работу мечты в партнёрстве. Сегодня мой доход составляет 500–700 тысяч рублей в месяц вместо прежних 150 тысяч.',
    author: 'Екатерина',
    result: 'Карьера и деньги',
    image: '/images/reviews/ekaterina.webp',
  },
  {
    quote:
      'Через два месяца после консультации я подписала контракт с Coca-Cola на 30 миллионов рублей. Самым удивительным оказалось то, насколько точно были описаны мои сильные стороны и роль партнёрства в моём росте.',
    author: 'Ольга',
    result: 'Крупный контракт',
    image: '/images/reviews/olga.webp',
  },
  {
    quote:
      'Я пришла скорее из любопытства. В итоге получила не прогнозы, а очень глубокое понимание себя. После встречи я перестала сомневаться в своём выборе и впервые по-настоящему поверила в себя.',
    author: 'Анастасия',
    result: 'Самоопределение',
    image: '/images/reviews/anastasia.webp',
  },
  {
    quote:
      'Я пришла в полном тупике и не понимала, куда двигаться дальше. Сейчас у меня есть ясность, направление и ощущение внутренней силы. Никакой эзотерики — только факты и очень точные наблюдения.',
    author: 'Лиза',
    result: 'Новый жизненный вектор',
    image: '/images/reviews/liza.webp',
  },
];
---

<section class="reviews" id="reviews">
  <div class="reviews__inner">
    <div class="reviews__head">
      <p class="reviews__eyebrow">Отзывы</p>
      <h2>После консультации</h2>
    </div>

    <div class="reviews__grid">
      {
        reviews.map((review) => (
          <article class="review-card">
            <div class="review-card__top">
              <p class="review-card__result">{review.result}</p>
            </div>

            <blockquote>«{review.quote}»</blockquote>

            <div class="review-card__person">
              <img src={review.image} alt={review.author} loading="lazy" />

              <div>
                <p class="review-card__author">{review.author}</p>
                <p class="review-card__role">{review.result}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .reviews {
    position: relative;
    padding: clamp(86px, 10vw, 150px) 0;
    background: #fff;
    color: var(--text, #1f1d1b);
    overflow: hidden;
  }

  .reviews::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    width: min(1440px, calc(100% - 64px));
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(
      90deg,
      transparent,
      rgba(182, 70, 70, 0.22),
      transparent
    );
  }

  .reviews__inner {
    width: min(1440px, calc(100% - 64px));
    margin: 0 auto;
  }

  .reviews__head {
    max-width: 720px;
    margin-bottom: clamp(44px, 5vw, 70px);
  }

  .reviews__eyebrow {
    margin: 0 0 18px;
    color: var(--accent, #b64646);
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .reviews h2 {
    margin: 0;
    max-width: 650px;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(38px, 3.8vw, 56px);
    font-weight: 400;
    line-height: 1.04;
    letter-spacing: -0.03em;
  }

  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(320px, 1fr));
    gap: 18px;
    overflow-x: auto;
    padding-bottom: 18px;
    scroll-snap-type: x mandatory;
  }

  .reviews__grid::-webkit-scrollbar {
    height: 6px;
  }

  .reviews__grid::-webkit-scrollbar-track {
    background: rgba(31, 29, 27, 0.06);
  }

  .reviews__grid::-webkit-scrollbar-thumb {
    background: rgba(182, 70, 70, 0.34);
    border-radius: 999px;
  }

  .review-card {
    min-height: 430px;
    padding: clamp(26px, 3vw, 36px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #fbf8f4;
    border: 1px solid rgba(31, 29, 27, 0.08);
    border-radius: 30px;
    scroll-snap-align: start;
  }

  .review-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .review-card__result {
    margin: 0;
    color: var(--accent, #b64646);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .review-card blockquote {
    margin: 34px 0;
    color: rgba(31, 29, 27, 0.78);
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(22px, 1.8vw, 30px);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.032em;
  }

  .review-card__person {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 22px;
    border-top: 1px solid rgba(31, 29, 27, 0.08);
  }

  .review-card__person img {
    width: 52px;
    height: 52px;
    flex: 0 0 auto;
    display: block;
    object-fit: cover;
    border-radius: 50%;
    background: #eee5dc;
  }

  .review-card__author {
    margin: 0;
    color: rgba(31, 29, 27, 0.82);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.25;
  }

  .review-card__role {
    margin: 5px 0 0;
    color: rgba(31, 29, 27, 0.48);
    font-size: 12px;
    line-height: 1.3;
  }

  @media (max-width: 900px) {
    .reviews__grid {
      grid-template-columns: repeat(5, minmax(300px, 82vw));
    }

    .review-card {
      min-height: 400px;
    }
  }

  @media (max-width: 620px) {
    .reviews {
      padding: 68px 0;
    }

    .reviews__inner {
      width: calc(100% - 32px);
    }

    .reviews::before {
      width: calc(100% - 32px);
    }

    .reviews h2 {
      font-size: clamp(34px, 10vw, 46px);
    }

    .reviews__grid {
      grid-template-columns: repeat(5, minmax(280px, 86vw));
      gap: 14px;
    }

    .review-card {
      min-height: 370px;
      border-radius: 26px;
    }

    .review-card blockquote {
      font-size: 23px;
    }

    .review-card__person img {
      width: 48px;
      height: 48px;
    }
  }
</style>