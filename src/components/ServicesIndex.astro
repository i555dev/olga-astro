---
const services = [
  {
    number: '01',
    title: 'Натальная карта',
    text: 'Понять себя, таланты, деньги, отношения, сильные стороны и предназначение.',
    href: '/services/natal',
  },
  {
    number: '02',
    title: 'Прогноз на год',
    text: 'Увидеть важные периоды, благоприятные даты, решения и сценарии года.',
    href: '/services/solar',
  },
  {
    number: '03',
    title: 'Совместимость',
    text: 'Разобрать отношения, потребности партнёров и точки напряжения в паре.',
    href: '/services/synastry',
  },
  {
    number: '04',
    title: 'Обучение астрологии',
    text: 'Освоить астрологию как профессию или глубокий инструмент понимания себя.',
    href: '/services/education',
  },
  {
    number: '05',
    title: 'VIP',
    text: 'Комплексный разбор жизни, семьи или бизнеса с персональным сопровождением.',
    href: '/services/vip',
  },
  {
    number: '06',
    title: 'Астролог на мероприятие',
    text: 'Живой формат для корпоративов, конференций, праздников и закрытых событий.',
    href: '/services/events',
  },
];
---

<section class="services-index" id="services">
  <div class="services-index__inner">
    <div class="services-index__head">
      <p class="services-index__eyebrow">Услуги</p>
      <h2>Когда нужен конкретный разбор</h2>
      <p>
        Выберите формат, который ближе к вашему вопросу. Подробности, тарифы
        и состав консультации — на отдельной странице каждой услуги.
      </p>
    </div>

    <div class="services-index__grid">
      {services.map((service) => (
        <a class="service-card" href={service.href}>
          <span class="service-card__number">{service.number}</span>
          <div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </div>
          <span class="service-card__link">Подробнее</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services-index {
    position: relative;
    padding: clamp(72px, 9vw, 132px) 0;
    background:
      radial-gradient(circle at 8% 14%, rgba(151, 18, 32, 0.08), transparent 34%),
      linear-gradient(180deg, #ffffff 0%, #faf8f6 100%);
    color: #141111;
    overflow: hidden;
  }

  .services-index::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    width: min(1180px, calc(100% - 32px));
    height: 1px;
    transform: translateX(-50%);
  }

  .services-index__inner {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .services-index__head {
    max-width: 720px;
    margin-bottom: clamp(36px, 5vw, 64px);
  }

  .services-index__eyebrow {
    margin: 0 0 18px;
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #971220;
  }

  .services-index h2 {
    margin: 0;
    max-width: 680px;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(38px, 5.8vw, 74px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .services-index__head > p:last-child {
    margin: 24px 0 0;
    max-width: 560px;
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.55;
    color: rgba(20, 17, 17, 0.64);
  }

  .services-index__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .service-card {
    min-height: 310px;
    padding: clamp(24px, 3vw, 34px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(20, 17, 17, 0.1);
    border-radius: 28px;
    box-shadow: 0 24px 70px rgba(20, 17, 17, 0.055);
    transition:
      transform 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      background 0.35s ease;
  }

  .service-card:hover {
    transform: translateY(-6px);
    background: #ffffff;
    border-color: rgba(151, 18, 32, 0.36);
    box-shadow: 0 34px 90px rgba(20, 17, 17, 0.09);
  }

  .service-card__number {
    font-size: 12px;
    letter-spacing: 0.18em;
    color: rgba(151, 18, 32, 0.9);
  }

  .service-card h3 {
    margin: 0 0 18px;
    max-width: 270px;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .service-card p {
    margin: 0;
    max-width: 310px;
    font-size: 15px;
    line-height: 1.55;
    color: rgba(20, 17, 17, 0.62);
  }

  .service-card__link {
    width: fit-content;
    padding-bottom: 6px;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #971220;
    border-bottom: 1px solid rgba(151, 18, 32, 0.34);
  }

  @media (max-width: 900px) {
    .services-index__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .service-card {
      min-height: 280px;
    }
  }

  @media (max-width: 620px) {
    .services-index {
      padding: 72px 0;
    }

    .services-index__grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      min-height: 250px;
      border-radius: 24px;
    }
  }
</style>